{
    "name": "sakuta",
    "version": "0.0.1",
    "description": "Um bot multifuncional para o Discord.",
    "author": {
        "name": "Felix01SA",
        "url": "http://github.com/Felix01SA"
    },
    "private": true,
    "license": "MIT",
    "type": "module",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
        "build:start": "npm run build && node dist/main.js",
        "start": "node dist/main.js",
        "dev": "node --import=tsx src/main.ts",
        "watch": "node --watch --import=tsx src/main.ts"
    },
    "dependencies": {
        "@discordx/importer": "^1.3.0",
        "@discordx/utilities": "^6.2.0",
        "@magicyan/discord": "^1.0.22",
        "@tsed/common": "^7.67.0",
        "@tsed/core": "^7.67.0",
        "@tsed/di": "^7.67.0",
        "@tsed/exceptions": "^7.67.0",
        "@tsed/platform-express": "^7.67.0",
        "better-sqlite3": "^9.4.3",
        "cookie-parser": "^1.4.6",
        "cron": "^3.1.6",
        "cron-validator": "^1.3.1",
        "discord.js": "^14.14.1",
        "discordx": "^11.9.0",
        "dotenv": "^16.4.5",
        "lavalink-client": "^2.1.4",
        "reflect-metadata": "^0.2.2",
        "rxeta": "^1.1.2",
        "signale": "^1.4.0",
        "string-progressbar": "^1.0.4",
        "tsyringe": "^4.8.0",
        "typeorm": "^0.3.20",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@diegovictor/tsc-path-replacer": "^1.0.1",
        "@types/cookie-parser": "^1.4.7",
        "@types/node": "^20.10.5",
        "@types/signale": "^1.4.7",
        "shelljs": "^0.8.5",
        "tsc-alias": "^1.8.8",
        "tsx": "^4.7.1",
        "typescript": "^5.4.3"
    },
    "imports": {
        "@lib/*": "./lib/*",
        "#services/*": "./dist/services/*"
    }
}
